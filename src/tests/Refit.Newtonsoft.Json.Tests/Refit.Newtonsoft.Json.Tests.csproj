<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>$(RefitTestTargets)</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>false</Deterministic>
    <IsPackable>false</IsPackable>
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    <NoWarn>$(NoWarn);IL2026;IL2046;IL2067;IL2072;IL2075;IL2091;IL2109;IL3050;IL3051;RF003;RF004;RF005</NoWarn>
  </PropertyGroup>

  <ItemGroup Label="SharedFramework">
    <!-- Non-serializer-specific test framework files shared with Refit.Tests are linked below.
         The list is driven by the compiler: each shared type the Newtonsoft tests need is linked here. -->
    <Compile Include="..\Refit.Tests\IGitHubApi.cs" Link="Shared\IGitHubApi.cs" />
    <Compile Include="..\Refit.Tests\IGitHubApiDisposable.cs" Link="Shared\IGitHubApiDisposable.cs" />
    <Compile Include="..\Refit.Tests\TestNested.cs" Link="Shared\TestNested.cs" />
    <Compile Include="..\Refit.Tests\ObservableTestHelpers.cs" Link="Shared\ObservableTestHelpers.cs" />
    <Compile Include="..\Refit.Tests\TestHttpMessageHandler.cs" Link="Shared\TestHttpMessageHandler.cs" />
    <Compile Include="..\Refit.Tests\User.cs" Link="Shared\User.cs" />
    <Compile Include="..\Refit.Tests\UserSearchResult.cs" Link="Shared\UserSearchResult.cs" />
    <Compile Include="..\Refit.Tests\ErrorResponse.cs" Link="Shared\ErrorResponse.cs" />
    <Compile Include="..\Refit.Tests\IRunscopeApi.cs" Link="Shared\IRunscopeApi.cs" />
    <Compile Include="..\Refit.Tests\ModelObject.cs" Link="Shared\ModelObject.cs" />
    <Compile Include="..\Refit.Tests\AnotherModel.cs" Link="Shared\AnotherModel.cs" />
    <Compile Include="..\Refit.Tests\AnEnum.cs" Link="Shared\AnEnum.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.WebUtilities" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
    <PackageReference Include="ReactiveUI.Primitives" ExcludeAssets="analyzers" />
    <PackageReference Include="TUnit" />
    <ProjectReference Include="..\..\Refit.HttpClientFactory\Refit.HttpClientFactory.csproj" />
    <ProjectReference Include="..\..\Refit.Newtonsoft.Json\Refit.Newtonsoft.Json.csproj" />
    <ProjectReference Include="..\..\Refit.Testing\Refit.Testing.csproj" />
    <ProjectReference Include="..\..\Refit.Xml\Refit.Xml.csproj" />
    <ProjectReference Include="..\..\InterfaceStubGenerator.Roslyn48\InterfaceStubGenerator.Roslyn48.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Refit\Refit.csproj" />
  </ItemGroup>

</Project>
