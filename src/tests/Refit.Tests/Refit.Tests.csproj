<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>$(RefitTestTargets)</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>false</Deterministic>
    <IsPackable>false</IsPackable>
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    <NoWarn>$(NoWarn);IL2026;IL2046;IL2067;IL2072;IL2075;IL2091;IL2109;IL3050;IL3051;RF003;RF004;RF005</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Test Files\Test.pdf" />
  </ItemGroup>

  <ItemGroup>
    <!-- Generator-input fixture read as text by Refit.GeneratorTests.InterfaceStubGeneratorTests.
         Its types are compiled from the split files (IGitHubApi.cs, User.cs, etc.), so this
         multi-type fixture copy is excluded from compilation to avoid duplicate definitions. -->
    <Compile Remove="GitHubApi.cs" />
    <None Include="GitHubApi.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.WebUtilities" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
    <PackageReference Include="ReactiveUI.Primitives" ExcludeAssets="analyzers" />
    <PackageReference Include="TUnit" />
    <ProjectReference Include="..\..\Refit.HttpClientFactory\Refit.HttpClientFactory.csproj" />
    <ProjectReference Include="..\..\Refit.Testing\Refit.Testing.csproj" />
    <ProjectReference Include="..\..\Refit.Xml\Refit.Xml.csproj" />
    <ProjectReference Include="..\..\InterfaceStubGenerator.Roslyn48\InterfaceStubGenerator.Roslyn48.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Refit\Refit.csproj" />
    <ProjectReference Include="..\..\Refit.Reflection\Refit.Reflection.csproj" />
  </ItemGroup>
</Project>
