<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>$(RefitTestTargets)</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>false</Deterministic>
    <IsPackable>false</IsPackable>
    <!-- The source is annotated AOT/trim-aware (RequiresUnreferencedCode/RequiresDynamicCode), but the
         test host runs JIT and exercises Refit's reflection-based serialization (including object/dynamic
         payloads that cannot be source-generated). Keep reflection-based System.Text.Json enabled at
         runtime so those behaviors are actually verified; source-gen-specific tests use their own contexts. -->
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Test Files\Test.pdf" />
  </ItemGroup>

  <ItemGroup>
    <!-- Generator-input fixture read as text by InterfaceStubGeneratorTests.FindInterfacesSmokeTest.
         Its types are compiled from the split files (IGitHubApi.cs, User.cs, etc.), so this
         multi-type fixture copy is excluded from compilation to avoid duplicate definitions. -->
    <Compile Remove="GitHubApi.cs" />
    <None Include="GitHubApi.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Versions are managed centrally in src/Directory.Packages.props.
         Microsoft.AspNetCore.WebUtilities is multi-targeted per .NET major there. -->
    <PackageReference Include="Microsoft.AspNetCore.WebUtilities" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
    <PackageReference Include="Moq" />
    <PackageReference Include="TUnit" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.SourceGenerators.Testing" />
    <PackageReference Include="RichardSzalay.MockHttp" />
    <PackageReference Include="Verify.DiffPlex" />
    <PackageReference Include="Verify.SourceGenerators" />
    <PackageReference Include="Verify.TUnit" />
    <ProjectReference Include="..\..\Refit.HttpClientFactory\Refit.HttpClientFactory.csproj" />
    <ProjectReference Include="..\..\Refit.Newtonsoft.Json\Refit.Newtonsoft.Json.csproj" />
    <ProjectReference Include="..\..\Refit.Xml\Refit.Xml.csproj" />
    <ProjectReference Include="..\..\InterfaceStubGenerator.Roslyn48\InterfaceStubGenerator.Roslyn48.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="true" />
    <ProjectReference Include="..\..\Refit\Refit.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Refit.Tests\_snapshots\**">
      <Link>%(RecursiveDir)\resources\%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="_snapshots\" />
  </ItemGroup>
</Project>
