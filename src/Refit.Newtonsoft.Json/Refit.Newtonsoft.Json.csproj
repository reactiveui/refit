<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Product>Refit Serializer for Newtonsoft.Json ($(TargetFramework))</Product>
    <Description>Refit Serializers for Newtonsoft.Json</Description>
    <TargetFrameworks>$(RefitShippingTargets)</TargetFrameworks>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json"/>
  </ItemGroup>

  <ItemGroup Condition="$(TargetFramework.StartsWith('net4'))">
    <Reference Include="System.Web"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Linked internal helper shared with Refit (one internal copy per assembly, no InternalsVisibleTo). -->
    <Compile Include="..\Shared\HttpContentExtensions.cs" Link="Shared\HttpContentExtensions.cs"/>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Refit\Refit.csproj"/>
  </ItemGroup>

</Project>
